{
  "name": "maze",
  "version": "1.1.0",
  "description": "一个可用于随机生成迷宫的游戏软件",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package": "vite build && electron-builder --publish never",
    "preview": "vite preview",
    "package:dev": "vite build && electron-builder --publish never",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "keywords": [
    "electron",
    "vue3",
    "typescript",
    "maze",
    "desktop-app"
  ],
  "author": "MonoKelvin",
  "license": "MIT",
  "dependencies": {
    "@primevue/themes": "^4.5.4",
    "electron-store": "^9.0.0",
    "lucide-vue-next": "^0.458.0",
    "pinia": "^2.2.0",
    "primevue": "^4.2.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/tsconfig": "^0.7.0",
    "electron": "^30.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.26.0",
    "prettier": "^3.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^2.0.0",
    "vue-tsc": "^2.1.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "package": "vite build && electron-builder --publish never",
    "package:dev": "vite build && electron-builder --publish never",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  }
}
